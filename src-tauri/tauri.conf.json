{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Systamator v2",
  "version": "0.1.0",
  "identifier": "com.systamator.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Systamator v2",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/32x32.png", "icons/128x128.png"],
    "category": "DeveloperTool",
    "shortDescription": "Agent-first infrastructure OS"
  }
}
